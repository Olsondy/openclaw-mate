{
  "productName": "ClawMate",
  "version": "0.1.0",
  "identifier": "com.easy-openclaw.clawmate",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run runtime:prepare && pnpm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ClawMate",
        "width": 980,
        "height": 680,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "resizable": true,
        "windowEffects": {
          "effects": ["mica"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_PUBKEY",
      "endpoints": [
        "https://github.com/YOUR_USERNAME/YOUR_REPO/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "runtime/openclaw": "runtime/openclaw"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
